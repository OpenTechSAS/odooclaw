# ── Execution Environment (Doodba / Docker) ──────────────────────────
# This file is an example of the environment variables you can
# use to configure OdooClaw without modifying config.json.
# If you are using Doodba, you can copy the contents of this file
# into your `.docker/odoo.env` or main `.env` file.

# ── Odoo Credentials (Required for the Module) ──────────────────────────
ODOO_URL=http://odoo:8069
ODOO_DB=devel
ODOO_USERNAME=admin
# In production, NEVER use the admin password. Create an API Key in Odoo.
ODOO_PASSWORD=admin

# ── LLM Provider ──────────────────────────
# Configure the default model OdooClaw will use
ODOOCLAW_AGENTS_DEFAULTS_PROVIDER=openai
ODOOCLAW_AGENTS_DEFAULTS_MODEL=gpt-4o

# Uncomment and configure your main AI provider:
OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1

# If you prefer to use other providers (Optional):
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# GEMINI_API_KEY=xxx
# CEREBRAS_API_KEY=xxx

# ── Odoo Gateway (Webhook) ──────────────────────────
ODOOCLAW_CHANNELS_ODOO_ENABLED=true
ODOOCLAW_CHANNELS_ODOO_WEBHOOK_HOST=0.0.0.0
ODOOCLAW_CHANNELS_ODOO_WEBHOOK_PORT=18790
ODOOCLAW_CHANNELS_ODOO_WEBHOOK_PATH=/webhook/odoo

# ── Other Chat Channels (Optional) ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (Optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Europe/Madrid
