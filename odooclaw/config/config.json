{
  "agents": {
    "defaults": {
      "workspace": "/home/odooclaw/.odooclaw/workspace",
      "restrict_to_workspace": true,
      "provider": "groq",
      "model_name": "llama-3.1-8b-instant",
      "max_tokens": 8192,
      "max_tool_iterations": 10
    }
  },
  "channels": {
    "odoo": {
      "enabled": true,
      "webhook_host": "0.0.0.0",
      "webhook_port": 18790,
      "webhook_path": "/webhook/odoo"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "tools": {
    "mcp": {
      "enabled": true,
      "servers": {
        "odoo-manager": {
          "enabled": true,
          "command": "python3",
          "args": ["/usr/local/bin/odoo-mcp.py"]
        }
      }
    }
  }
}
